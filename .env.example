# Copy this file to .env and fill in real local values.
# Do not commit .env.

# Required for PostGIS/Supabase-backed analysis and walking routes.
user=postgres.your_project_ref
password=replace_me
host=aws-1-eu-west-1.pooler.supabase.com
port=6543
dbname=postgres

# Optional routing defaults.
ROUTING_DRIVING_BASE_URL=https://router.project-osrm.org
ROUTING_DRIVING_PROFILE=driving

# Optional walking-network settings.
WALKING_NETWORK_TABLE=vegnett_pluss_gangnett
WALKING_NETWORK_CACHE_TTL_SECONDS=300
WALKING_MAX_SNAP_DISTANCE_METERS=1500
WALKING_SPEED_MPS=1.4
WALKING_CONNECTOR_SPEED_MPS=1.4
WALKING_TRAIL_SPEED_MPS=1.2
WALKING_TRACTOR_ROAD_SPEED_MPS=1.3
WALKING_STAIRS_SPEED_MPS=0.8
WALKING_CROSSING_SPEED_MPS=1.1
WALKING_JUNCTION_SPEED_MPS=1.15
WALKING_EDGE_CANDIDATE_LIMIT=6
WALKING_SHELTER_EDGE_CANDIDATE_LIMIT=40
WALKING_TARGET_ACCESS_CANDIDATE_LIMIT=8
WALKING_SHELTER_TARGET_ACCESS_CANDIDATE_LIMIT=12
WALKING_TARGET_ACCESS_MARGIN_METERS=35
WALKING_TARGET_ACCESS_SCAN_LIMIT=32
WALKING_SHELTER_ACCESS_MARGIN_METERS=20
WALKING_NEAREST_HOSPITAL_POINT_LIMIT=0
WALKING_NEAREST_LEGEVAKT_POINT_LIMIT=24
WALKING_NEAREST_SHELTER_POINT_LIMIT=32

# Optional Geonorge tilfluktsrom API settings.
SHELTER_METADATA_UUID=dbae9aae-10e7-4b75-8d67-7f0e8828f3d8
SHELTER_CAPABILITIES_URL=https://nedlasting.geonorge.no/api/capabilities/dbae9aae-10e7-4b75-8d67-7f0e8828f3d8
SHELTER_ORDER_URL=https://nedlasting.geonorge.no/api/order
SHELTER_CACHE_TTL_SECONDS=1800
SHELTER_ORDER_STATUS_POLL_ATTEMPTS=6
SHELTER_ORDER_STATUS_POLL_SECONDS=1.0
